{
  "id": "um-switch-tabs",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-switch-tabs",
    "title": "Switch tabs: User Management to Roles & Access and back",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin page",
        "value": "https://ukg-atlas.vercel.app/admin"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User Management tab active",
        "locatorHint": "[data-testid=tab-user-management][aria-selected='true']"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Click Roles & Access tab",
        "locatorHint": "[data-testid=tab-roles-access]"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Roles & Access view visible",
        "locatorHint": "[data-testid=roles-access-view]"
      },
      {
        "id": "s7",
        "action": "tap",
        "targetDescription": "Click User Management tab",
        "locatorHint": "[data-testid=tab-user-management]"
      },
      {
        "id": "s8",
        "action": "waitForVisible",
        "targetDescription": "User table visible again",
        "locatorHint": "[data-testid=user-table]"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
