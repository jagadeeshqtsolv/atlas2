{
  "id": "um-own-row-protected",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-own-row-protected",
    "title": "Admin's own row: toggle disabled and tooltip on hover",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin page",
        "value": "https://ukg-atlas.vercel.app/admin"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Own admin row visible",
        "locatorHint": "tbody [data-testid=own-user-row]"
      },
      {
        "id": "s5",
        "action": "assertDisabled",
        "targetDescription": "Own toggle disabled",
        "locatorHint": "tbody [data-testid=own-user-row] [data-testid=access-toggle]"
      },
      {
        "id": "s6",
        "action": "hover",
        "targetDescription": "Hover own toggle",
        "locatorHint": "tbody [data-testid=own-user-row] [data-testid=access-toggle]"
      },
      {
        "id": "s7",
        "action": "waitForVisible",
        "targetDescription": "Tooltip visible",
        "locatorHint": "[role=tooltip]"
      },
      {
        "id": "s8",
        "action": "assertText",
        "targetDescription": "Tooltip text",
        "locatorHint": "[role=tooltip]",
        "assertion": "You cannot revoke your own access."
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
