{
  "id": "um-userinfo-email-only",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-userinfo-email-only",
    "title": "User information cell: email-only account shows email as primary and avatar initials fallback",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Admin with an email-only user",
        "value": "https://ukg-atlas.vercel.app/admin?seed=email-only-user"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=user-table]"
      },
      {
        "id": "s5",
        "action": "fill",
        "targetDescription": "Search email-only user",
        "locatorHint": "[data-testid=search-user]",
        "value": "no-name@example.com"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Email-only user row",
        "locatorHint": "tbody [data-testid=user-row][data-email='no-name@example.com']"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "Avatar initials (no photo)",
        "locatorHint": "tbody [data-testid=user-row][data-email='no-name@example.com'] [data-testid=avatar-initials]"
      },
      {
        "id": "s8",
        "action": "assertHidden",
        "targetDescription": "Full name element not shown",
        "locatorHint": "tbody [data-testid=user-row][data-email='no-name@example.com'] [data-testid=user-full-name]"
      },
      {
        "id": "s9",
        "action": "assertText",
        "targetDescription": "Primary line shows email",
        "locatorHint": "tbody [data-testid=user-row][data-email='no-name@example.com'] [data-testid=user-email]",
        "assertion": "no-name@example.com"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
