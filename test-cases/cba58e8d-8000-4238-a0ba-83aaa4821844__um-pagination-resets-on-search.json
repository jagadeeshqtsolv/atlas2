{
  "id": "um-pagination-resets-on-search",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-pagination-resets-on-search",
    "title": "Pagination resets to page 1 when search query changes on page 2",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Admin with 50 users",
        "value": "https://ukg-atlas.vercel.app/admin?seed=users-50"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=user-table]"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Go to page 2 via Next",
        "locatorHint": "[data-testid=pagination] button:has-text('Next')"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Page 2 active indicator",
        "locatorHint": "[data-testid=pagination] button[aria-current='page']:has-text('2')"
      },
      {
        "id": "s7",
        "action": "fill",
        "targetDescription": "Type one character into Search user",
        "locatorHint": "[data-testid=search-user]",
        "value": "a"
      },
      {
        "id": "s8",
        "action": "waitForVisible",
        "targetDescription": "Page 1 active indicator after search",
        "locatorHint": "[data-testid=pagination] button[aria-current='page']:has-text('1')"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
