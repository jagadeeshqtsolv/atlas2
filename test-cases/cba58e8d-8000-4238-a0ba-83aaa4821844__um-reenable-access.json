  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-reenable-access",
    "title": "Re-enable access from OFF: immediate without confirmation (Carol Jones)",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Admin with user Carol Jones having OFF access",
        "value": "https://ukg-atlas.vercel.app/admin?seed=carol-off"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=user-table]"
      },
      {
        "id": "s5",
        "action": "fill",
        "targetDescription": "Search Carol Jones",
        "locatorHint": "[data-testid=search-user]",
        "value": "Carol Jones"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Carol Jones row",
        "locatorHint": "tbody [data-testid=user-row][data-name='Carol Jones']"
      },
      {
        "id": "s7",
        "action": "assertUnchecked",
        "targetDescription": "Access toggle is OFF",
        "locatorHint": "tbody [data-testid=user-row][data-name='Carol Jones'] [data-testid=access-toggle]"
      },
      {
        "id": "s8",
        "action": "tap",
        "targetDescription": "Click access toggle to enable",
        "locatorHint": "tbody [data-testid=user-row][data-name='Carol Jones'] [data-testid=access-toggle]"
      },
      {
        "id": "s9",
        "action": "wait",
        "targetDescription": "Short wait to ensure no dialog appears"
      },
      {
        "id": "s10",
        "action": "assertChecked",
        "targetDescription": "Access toggle now ON",
        "locatorHint": "tbody [data-testid=user-row][data-name='Carol Jones'] [data-testid=access-toggle]"
      },
      {
        "id": "s11",
        "action": "assertHidden",
        "targetDescription": "No confirmation dialog shown",
        "locatorHint": "[role=dialog]"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
