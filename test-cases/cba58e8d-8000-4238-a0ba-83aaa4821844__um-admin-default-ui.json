{
  "id": "um-admin-default-ui",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-admin-default-ui",
    "title": "Admin loads /admin: default User Management tab, tabs order, header elements, and table columns render",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin page",
        "value": "https://ukg-atlas.vercel.app/admin"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User Management tab active",
        "locatorHint": "[data-testid=tab-user-management][aria-selected='true']"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Tab 1 label",
        "locatorHint": "[data-testid=admin-tabs] [role=tab]:nth-child(1)",
        "assertion": "User Management"
      },
      {
        "id": "s6",
        "action": "assertText",
        "targetDescription": "Tab 2 label",
        "locatorHint": "[data-testid=admin-tabs] [role=tab]:nth-child(2)",
        "assertion": "Roles & Access"
      },
      {
        "id": "s7",
        "action": "assertText",
        "targetDescription": "Tab 3 label",
        "locatorHint": "[data-testid=admin-tabs] [role=tab]:nth-child(3)",
        "assertion": "Audit Log"
      },
      {
        "id": "s8",
        "action": "assertVisible",
        "targetDescription": "\"N Users\" count label",
        "locatorHint": "[data-testid=users-count]"
      },
      {
        "id": "s9",
        "action": "assertVisible",
        "targetDescription": "Search user input",
        "locatorHint": "[data-testid=search-user]"
      },
      {
        "id": "s10",
        "action": "assertVisible",
        "targetDescription": "Invite user button",
        "locatorHint": "[data-testid=invite-user]"
      },
      {
        "id": "s11",
        "action": "assertCount",
        "targetDescription": "Table header has exactly 5 columns",
        "locatorHint": "thead th"
      },
      {
        "id": "s12",
        "action": "assertText",
        "targetDescription": "Column 1 label",
        "locatorHint": "thead th:nth-child(1)",
        "assertion": "User information"
      },
      {
        "id": "s13",
        "action": "assertText",
        "targetDescription": "Column 2 label",
        "locatorHint": "thead th:nth-child(2)",
        "assertion": "Role"
      },
      {
        "id": "s14",
        "action": "assertText",
        "targetDescription": "Column 3 label",
        "locatorHint": "thead th:nth-child(3)",
        "assertion": "Status"
      },
      {
        "id": "s15",
        "action": "assertText",
        "targetDescription": "Column 4 label",
        "locatorHint": "thead th:nth-child(4)",
        "assertion": "Last active"
      },
      {
        "id": "s16",
        "action": "assertText",
        "targetDescription": "Column 5 label",
        "locatorHint": "thead th:nth-child(5)",
        "assertion": "Account Access"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
