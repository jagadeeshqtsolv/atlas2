{
  "id": "um-status-badges-and-inactive-toggle",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-status-badges-and-inactive-toggle",
    "title": "Status badges show Active/Inactive and inactive user's toggle is OFF",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Admin with mixed statuses",
        "value": "https://ukg-atlas.vercel.app/admin?seed=mix-statuses"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=user-table]"
      },
      {
        "id": "s5",
        "action": "assertCountGreaterThan",
        "targetDescription": "At least one Active badge present",
        "locatorHint": "tbody [data-testid=status-badge][data-status='Active']"
      },
      {
        "id": "s6",
        "action": "assertCountGreaterThan",
        "targetDescription": "At least one Inactive badge present",
        "locatorHint": "tbody [data-testid=status-badge][data-status='Inactive']"
      },
      {
        "id": "s7",
        "action": "assertUnchecked",
        "targetDescription": "First Inactive row toggle is OFF",
        "locatorHint": "tbody [data-testid=user-row][data-status='Inactive'] [data-testid=access-toggle]"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
