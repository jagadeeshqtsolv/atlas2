{
  "id": "revoke-access-confirm-on-toggle",
  "testPlanId": "3927a745-0090-45ef-8f05-78527a5a8d06",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management: SMOKE",
  "case": {
    "id": "revoke-access-confirm-on-toggle",
    "title": "Revoke access: clicking ON toggle prompts confirmation; confirming turns toggle OFF",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce Login button",
        "locatorHint": "button:has-text(\"Salesforce\")"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "Any ON account access toggle on user row",
        "locatorHint": "table tbody tr input.access-toggle:checked",
        "value": "10000"
      },
      {
        "id": "s4",
        "action": "tap",
        "targetDescription": "Click an ON toggle (teal)",
        "locatorHint": "table tbody tr input.access-toggle:checked"
      },
      {
        "id": "s5",
        "action": "waitForVisible",
        "targetDescription": "Confirmation dialog appears",
        "locatorHint": "[role=\"dialog\"]:has-text(\"Revoke access?\")",
        "value": "5000"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Confirm revoke",
        "locatorHint": "[role=\"dialog\"] button:has-text(\"Revoke\")"
      },
      {
        "id": "s7",
        "action": "waitForHidden",
        "targetDescription": "Dialog closes",
        "locatorHint": "[role=\"dialog\"]",
        "value": "5000"
      },
      {
        "id": "s8",
        "action": "assertVisible",
        "targetDescription": "An OFF (grey) toggle is present",
        "locatorHint": "table tbody tr input.access-toggle:not(:checked)"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
