{
  "id": "um-revoke-access-confirm",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-revoke-access-confirm",
    "title": "Revoke access: confirmation dialog and toggle turns OFF (Alice Doe)",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Admin with active user Alice Doe",
        "value": "https://ukg-atlas.vercel.app/admin?seed=alice-active"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=user-table]"
      },
      {
        "id": "s5",
        "action": "fill",
        "targetDescription": "Search Alice Doe",
        "locatorHint": "[data-testid=search-user]",
        "value": "Alice Doe"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Alice Doe row",
        "locatorHint": "tbody [data-testid=user-row][data-name='Alice Doe']"
      },
      {
        "id": "s7",
        "action": "assertContainsText",
        "targetDescription": "Status is Active",
        "locatorHint": "tbody [data-testid=user-row][data-name='Alice Doe'] [data-testid=status-badge]",
        "assertion": "Active"
      },
      {
        "id": "s8",
        "action": "assertChecked",
        "targetDescription": "Access toggle is ON",
        "locatorHint": "tbody [data-testid=user-row][data-name='Alice Doe'] [data-testid=access-toggle]"
      },
      {
        "id": "s9",
        "action": "tap",
        "targetDescription": "Click access toggle",
        "locatorHint": "tbody [data-testid=user-row][data-name='Alice Doe'] [data-testid=access-toggle]"
      },
      {
        "id": "s10",
        "action": "waitForVisible",
        "targetDescription": "Confirmation dialog",
        "locatorHint": "[role=dialog]"
      },
      {
        "id": "s11",
        "action": "assertText",
        "targetDescription": "Dialog title",
        "locatorHint": "[role=dialog] [data-testid=confirm-title]",
        "assertion": "Revoke access?"
      },
      {
        "id": "s12",
        "action": "assertContainsText",
        "targetDescription": "Dialog message includes Alice Doe",
        "locatorHint": "[role=dialog] [data-testid=confirm-message]",
        "assertion": "This will prevent Alice Doe from accessing the portal."
      },
      {
        "id": "s13",
        "action": "tap",
        "targetDescription": "Click Revoke (destructive)",
        "locatorHint": "[role=dialog] button:has-text('Revoke')"
      },
      {
        "id": "s14",
        "action": "waitForHidden",
        "targetDescription": "Dialog closes",
        "locatorHint": "[role=dialog]"
      },
      {
        "id": "s15",
        "action": "assertUnchecked",
        "targetDescription": "Access toggle now OFF",
        "locatorHint": "tbody [data-testid=user-row][data-name='Alice Doe'] [data-testid=access-toggle]"
      },
      {
        "id": "s16",
        "action": "assertContainsText",
        "targetDescription": "Status updated to Inactive (if applicable)",
        "locatorHint": "tbody [data-testid=user-row][data-name='Alice Doe'] [data-testid=status-badge]",
        "assertion": "Inactive"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
