{
  "id": "um-search-case-insensitive",
  "testPlanId": "cba58e8d-8000-4238-a0ba-83aaa4821844",
  "requirementId": "6229f24a-b1f7-4e69-bd00-47e4e1fe6fb2",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "um-search-case-insensitive",
    "title": "Search filters users case-insensitively and in real time",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Admin with a known 'John Doe' user",
        "value": "https://ukg-atlas.vercel.app/admin?seed=has-john"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=user-table]"
      },
      {
        "id": "s5",
        "action": "fill",
        "targetDescription": "Type mixed-case query into Search user",
        "locatorHint": "[data-testid=search-user]",
        "value": "JoHn"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Row containing John Doe visible",
        "locatorHint": "tbody [data-testid=user-row][data-name*='John Doe']"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "\"N Users\" count label remains visible",
        "locatorHint": "[data-testid=users-count]"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
